# Auto detect text files and perform LF normalization
*        text=auto

# Always perform LF normalization on these files
*.dart   text
*.gradle text
*.html   text
*.java   text
*.json   text
*.md     text
*.py     text
*.sh     text
*.txt    text
*.xml    text
*.yaml   text

# Make sure that these Windows files always have CRLF line endings in checkout
*.bat             text eol=crlf
*.ps1             text eol=crlf
*.rc              text eol=crlf
*.sln             text eol=crlf
*.props           text eol=crlf
*.vcxproj         text eol=crlf
*.vcxproj.filters text eol=crlf
# Including templatized versions.
*.sln.tmpl        text eol=crlf
*.props.tmpl      text eol=crlf
*.vcxproj.tmpl    text eol=crlf

# Make sure that these Linux files always have LF line endings in checkout
bin/flutter       text eol=lf
bin/flutter-dev   text eol=lf
bin/dart          text eol=lf

# Never perform LF normalization on these files
*.ico    binary
*.jar    binary
*.png    binary
*.zip    binary

# Exclude all native platform initialization build content (Android, iOS, Web, Windows, macOS, Linux)
android/** linguist-vendored
ios/** linguist-vendored
web/** linguist-vendored
windows/** linguist-vendored
macos/** linguist-vendored
linux/** linguist-vendored

# Exclude auto-generated code files (such as files generated by build_runner)
*.g.dart linguist-vendored
*.freezed.dart linguist-vendored
*.generated.dart linguist-vendored